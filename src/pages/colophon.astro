---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Colophon from "../components/Colophon.astro";

const meta = [
  ["ROLE", "Designer & director (solo)"],
  ["STACK", "Pencil · Astro · Claude · Vercel"],
  ["SOURCE", "github.com/jihanRaihana/porto-jihan-web"],
  ["SHIPPED", "June 2026"],
];

const notes = [
  {
    n: "01",
    tag: "CONCEPT",
    head: "The concept — “Fieldwork”",
    body: "I started with a metaphor: a self-taught designer mapping unfamiliar territory, and the portfolio is the map she drew plus the notes she took. Cartography became the chrome — coordinates, contours, plotted project points, a compass. Three typefaces, each with a job: Geist Mono as the instrument, Playfair Display for place, Inter as the field hand.",
  },
  {
    n: "02",
    tag: "PENCIL",
    head: "Designed in Pencil",
    body: "Every screen was designed frame-by-frame in Pencil, an AI-augmented design tool. I built the nav and footer once as reusable components, documented the whole system in a Legend Sheet, and wrote the motion spec in a separate notes frame — before a single line of code.",
  },
  {
    n: "03",
    tag: "BUILD",
    head: "Built as a real site",
    body: "Then I turned the design into a working website: Astro for speed, plain CSS for the brand tokens, the nav and footer reused across every page. I don't come from a coding background. I directed Claude to write the code, made the calls, and checked the result at every step.",
  },
  {
    n: "04",
    tag: "MOTION",
    head: "Motion, on purpose",
    body: "The movement isn't decoration — it's wayfinding. A route-line plots your scroll down the margin; the map's points pulse like radar; the contour lines breathe. All of it calm, fast, and it falls back to perfectly still for anyone who prefers reduced motion.",
  },
  {
    n: "05",
    tag: "LIVE",
    head: "Interactive, not screenshots",
    body: "Where a static image would undersell it, I embedded live simulators instead — the Lilist onboarding and receipt-scan flows run right inside the case study, as self-contained prototypes you can actually play with.",
  },
  {
    n: "06",
    tag: "SHIPPED",
    head: "Shipped it myself",
    body: "Finally I put it online: deployed on Vercel (it now re-deploys automatically on every change) and pointed to my own domain. From the first sketch to a live URL — by me.",
  },
];

const rings = [660, 560, 460, 360, 260, 160];
---

<Base title="Colophon — How this site was made — Jihan Raihana" description="How this portfolio was designed, built, and shipped end-to-end — an honest, AI-augmented process note.">
  <Nav />

  <!-- ===== HEADER ===== -->
  <section class="th">
    <div class="header__contour" aria-hidden="true" data-parallax="0.12">
      {rings.map((d, i) => (
        <span style={`width:${d}px;height:${d}px;left:${i * 50}px;top:${i * 50}px;`}></span>
      ))}
    </div>
    <div class="wrap th__inner">
      <div class="th__breadcrumb">
        <a href="/" class="th__back">← BACK TO MAP</a>
        <span class="th__idx">FIELD NOTES — THE MAP ITSELF</span>
      </div>
      <p class="th__eyebrow">COLOPHON</p>
      <h1 class="th__title">How this field guide was drawn.</h1>
      <p class="th__tagline">Designed, built, and shipped end-to-end — no developer, AI as my drafting table.</p>
      <p class="th__intro">
        This site is itself a small case study. I designed it, turned it into a
        real website, and put it online — directing an AI through every step.
        Here's the honest record of how it was made.
      </p>
      <div class="th__meta">
        {meta.map(([k, v]) => (
          <div class="metaitem">
            <span class="metaitem__k">{k}</span>
            <span class="metaitem__v">{v}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== FIELD NOTES ===== -->
  {notes.map((nt, i) => (
    <section class={`note ${i % 2 === 0 ? "note--raised" : "note--surface"}`}>
      <div class="wrap note__inner">
        <div class="rail">
          <span class="rail__num">{nt.n}</span>
          <span class="rail__tag">{nt.tag}</span>
        </div>
        <div class="note__main">
          <h2 class="note__head">{nt.head}</h2>
          <p class="note__body">{nt.body}</p>
        </div>
      </div>
    </section>
  ))}

  <!-- ===== HONEST NOTE ===== -->
  <section class="honest">
    <div class="wrap">
      <blockquote class="callout">
        <span class="callout__label">ON HONESTY</span>
        <p class="callout__quote">
          I'm a product designer, not a developer. The code here is AI-written;
          the judgment, taste, and direction are mine. Knowing what to build —
          and when to stop — is the work.
        </p>
      </blockquote>
    </div>
  </section>

  <!-- ===== CLOSING ===== -->
  <section class="closing">
    <div class="wrap closing__inner">
      <p class="closing__line">The map is never finished — but it's drawn well enough to share.</p>
      <div class="closing__links">
        <a href="/" class="mono-link mono-link--accent">← Back to the map</a>
        <a href="https://github.com/jihanRaihana/porto-jihan-web" target="_blank" rel="noopener" class="mono-link">View source ↗</a>
      </div>
    </div>
  </section>

  <Colophon />
</Base>

<style>
  /* ---------- HEADER ---------- */
  .th {
    position: relative;
    background: var(--surface);
    overflow: hidden;
  }
  .th__inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 26px;
    padding-top: 52px;
    padding-bottom: 72px;
  }
  .header__contour {
    position: absolute;
    top: -220px;
    right: -160px;
    width: 660px;
    height: 660px;
    opacity: 0.4;
    z-index: 0;
    pointer-events: none;
  }
  .header__contour span {
    position: absolute;
    border: 1px solid var(--contour);
    border-radius: 50%;
  }
  .th__breadcrumb {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    padding-bottom: 16px;
  }
  .th__back,
  .th__idx {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.1em;
  }
  .th__back {
    color: var(--accent);
  }
  .th__idx {
    color: var(--ink-secondary);
  }
  .th__eyebrow {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.16em;
    color: var(--accent);
  }
  .th__title {
    font-family: var(--font-display);
    font-size: 54px;
    font-weight: 500;
    line-height: 1.06;
    color: var(--ink);
    max-width: 920px;
  }
  .th__tagline {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 22px;
    line-height: 1.3;
    color: var(--ink-secondary);
    max-width: 760px;
  }
  .th__intro {
    font-size: 18px;
    line-height: 1.6;
    color: var(--ink-secondary);
    max-width: 720px;
  }
  .th__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 44px;
    margin-top: 22px;
    padding-top: 22px;
    border-top: 1px solid var(--border-subtle);
  }
  .metaitem {
    display: flex;
    flex-direction: column;
    gap: 5px;
  }
  .metaitem__k {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.05em;
    color: var(--ink-secondary);
  }
  .metaitem__v {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--ink);
  }

  /* ---------- FIELD NOTES ---------- */
  .note--raised {
    background: var(--surface-raised);
  }
  .note--surface {
    background: var(--surface);
  }
  .note__inner {
    display: flex;
    gap: 72px;
    align-items: flex-start;
    padding-top: 64px;
    padding-bottom: 64px;
  }
  .rail {
    width: 140px;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .rail__num {
    font-family: var(--font-display);
    font-size: 40px;
    font-weight: 500;
    line-height: 1;
    color: var(--accent);
  }
  .rail__tag {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--ink-secondary);
  }
  .note__main {
    max-width: 760px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .note__head {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 500;
    line-height: 1.15;
    color: var(--ink);
  }
  .note__body {
    font-size: 17px;
    line-height: 1.62;
    color: var(--ink-secondary);
  }

  /* ---------- HONEST NOTE ---------- */
  .honest {
    background: var(--surface-raised);
  }
  .honest .wrap {
    padding-top: 72px;
    padding-bottom: 72px;
  }
  .callout {
    margin: 0;
    max-width: 860px;
    border-left: 3px solid var(--accent);
    padding: 6px 0 6px 30px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .callout__label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    color: var(--accent);
  }
  .callout__quote {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 26px;
    line-height: 1.32;
    color: var(--ink);
  }

  /* ---------- CLOSING ---------- */
  .closing {
    background: var(--surface);
    border-top: 1px solid var(--border-subtle);
  }
  .closing__inner {
    padding-top: 80px;
    padding-bottom: 80px;
    display: flex;
    flex-direction: column;
    gap: 26px;
  }
  .closing__line {
    font-family: var(--font-display);
    font-size: 30px;
    font-weight: 500;
    line-height: 1.2;
    color: var(--ink);
    max-width: 820px;
  }
  .closing__links {
    display: flex;
    flex-wrap: wrap;
    gap: 28px;
    align-items: center;
  }
  .mono-link {
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.04em;
    color: var(--ink-secondary);
    transition: transform 0.18s ease;
  }
  .mono-link--accent {
    color: var(--accent);
  }
  .mono-link:hover {
    transform: translateX(3px);
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  /* ---------- RESPONSIVE ---------- */
  @media (max-width: 900px) {
    .note__inner {
      flex-direction: column;
      gap: 18px;
    }
    .rail {
      width: auto;
      flex-direction: row;
      align-items: baseline;
      gap: 12px;
    }
  }
  @media (max-width: 720px) {
    .th__title {
      font-size: 38px;
    }
    .note__head {
      font-size: 24px;
    }
    .callout__quote {
      font-size: 21px;
    }
    .closing__line {
      font-size: 24px;
    }
  }
</style>
