---
// Kerangka dasar yang dipakai SEMUA halaman.
// Tugasnya: pasang font, pasang kamus warna, dan kasih "lubang" (slot)
// tempat isi tiap halaman dimasukkan.
import "../styles/global.css";

const { title = "Jihan Raihana — Product Designer", description = "Portfolio Jihan Raihana, product designer." } = Astro.props;
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png?v=2" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png?v=2" />

    <!-- Font dari Google: Playfair Display, Inter, Geist Mono -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Playfair+Display:wght@500;600&family=Geist+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <!-- Aktifkan mode animasi sebelum halaman tampil (cegah "kedip").
         Kalau pengunjung minta sedikit gerak, mode ini tidak diaktifkan. -->
    <script is:inline>
      if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
        document.documentElement.classList.add("motion");
      }
    </script>
  </head>
  <body>
    <!-- Garis rute: penanda posisi scroll di margin kiri (metafora memplot rute) -->
    <div class="routeline" aria-hidden="true">
      <span class="routeline__track"></span>
      <span class="routeline__line"></span>
      <span class="routeline__dot"></span>
    </div>

    <slot />

    <script>
      const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      // Pengaman: kalau 3 detik ada elemen yang masih tersembunyi, tampilkan paksa
      const revealAll = () =>
        document
          .querySelectorAll("section, footer, [data-stagger], .map")
          .forEach((el) => el.classList.add("is-in"));
      setTimeout(revealAll, 3000);

      // Menu atas (blur saat scroll) + garis rute (penanda posisi scroll)
      const nav = document.querySelector(".nav");
      const routeline = document.querySelector(".routeline");
      const onScroll = () => {
        const y = window.scrollY;
        if (nav) nav.classList.toggle("is-scrolled", y > 8);
        if (routeline) {
          const max = document.documentElement.scrollHeight - window.innerHeight;
          const p = max > 0 ? Math.min(1, Math.max(0, y / max)) : 0;
          routeline.style.setProperty("--p", p.toFixed(4));
        }
      };
      onScroll();
      window.addEventListener("scroll", onScroll, { passive: true });
      window.addEventListener("resize", onScroll, { passive: true });

      if (reduce) {
        // Tanpa animasi: pastikan semua langsung tampil
        document
          .querySelectorAll("section, footer, [data-stagger], .map")
          .forEach((el) => el.classList.add("is-in"));
      } else {
        // Reveal: tiap section/footer & grup stagger muncul saat masuk layar
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((en) => {
              if (en.isIntersecting) {
                en.target.classList.add("is-in");
                io.unobserve(en.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: "0px 0px -8% 0px" }
        );
        document
          .querySelectorAll("section, footer, [data-stagger], [data-reveal]")
          .forEach((el) => io.observe(el));

        // Peta Home: gambar rute + munculkan titik
        const map = document.querySelector(".map");
        if (map) {
          const mo = new IntersectionObserver(
            (ents) => {
              ents.forEach((en) => {
                if (en.isIntersecting) {
                  map.classList.add("is-in");
                  mo.disconnect();
                }
              });
            },
            { threshold: 0.3 }
          );
          mo.observe(map);
        }

        // Angka statistik menghitung naik dari nol
        const counts = document.querySelectorAll(".stat__n");
        if (counts.length) {
          const co = new IntersectionObserver(
            (ents) => {
              ents.forEach((en) => {
                if (!en.isIntersecting) return;
                const el = en.target;
                co.unobserve(el);
                const m = el.textContent.trim().match(/^(\d+)(.*)$/);
                if (!m) return;
                const target = parseInt(m[1], 10);
                const suffix = m[2] || "";
                const dur = 1100;
                const t0 = performance.now();
                const tick = (now) => {
                  const p = Math.min(1, (now - t0) / dur);
                  const eased = 1 - Math.pow(1 - p, 3);
                  el.textContent = Math.round(target * eased) + suffix;
                  if (p < 1) requestAnimationFrame(tick);
                  else el.textContent = target + suffix;
                };
                requestAnimationFrame(tick);
              });
            },
            { threshold: 0.6 }
          );
          counts.forEach((el) => co.observe(el));
        }

        // Kontur "bernafas": bergeser sangat pelan saat scroll (parallax)
        const parallaxEls = document.querySelectorAll("[data-parallax]");
        if (parallaxEls.length) {
          let ticking = false;
          const updateParallax = () => {
            const vh = window.innerHeight;
            parallaxEls.forEach((el) => {
              const speed = parseFloat(el.dataset.parallax) || 0.08;
              const r = el.getBoundingClientRect();
              const center = r.top + r.height / 2;
              const offset = (vh / 2 - center) * speed;
              el.style.transform = `translate3d(0, ${offset.toFixed(1)}px, 0)`;
            });
            ticking = false;
          };
          const onParallax = () => {
            if (!ticking) {
              ticking = true;
              requestAnimationFrame(updateParallax);
            }
          };
          updateParallax();
          window.addEventListener("scroll", onParallax, { passive: true });
          window.addEventListener("resize", onParallax, { passive: true });
        }
      }
    </script>
  </body>
</html>
